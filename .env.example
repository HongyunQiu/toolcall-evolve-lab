# Copy to .env and adjust
#   cp .env.example .env
#   set -a; source .env; set +a

# vLLM / OpenAI-compatible Responses API base URL (must include /v1)
OSS120B_BASE_URL=http://127.0.0.1:8000/v1

# Model id served by vLLM
OSS120B_MODEL=openai/gpt-oss-120b

# Optional: for OpenAI-compatible servers that require auth.
# For local vLLM typically unused.
OPENAI_API_KEY=
